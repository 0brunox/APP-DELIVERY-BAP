# Copie este arquivo para .env.local e preencha com as chaves do seu projeto Supabase.
# (Project Settings -> API, no painel do Supabase)

# URL do projeto (ex.: https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública "anon" (pode ir para o cliente; protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
