# =============================================================================
# Variáveis de ambiente — Delivery Super App
#
# LOCAL:  copie este arquivo para .env.local e preencha com as chaves do seu
#         projeto Supabase (Project Settings -> API, no painel do Supabase).
# VERCEL: configure estas MESMAS variáveis em
#         Project -> Settings -> Environment Variables (Production + Preview).
#
# O arquivo .env.local é ignorado pelo git (não sobe para o repositório).
# =============================================================================

# URL do projeto Supabase (ex.: https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública do Supabase — aceita o formato novo "sb_publishable_..."
# ou a "anon public" key clássica (JWT). Pode ir para o cliente: é protegida por RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Web Push (Etapa 7D) — notificações de novo pedido / status.
# Gere o par de chaves uma vez com:  npx web-push generate-vapid-keys --json
# A pública vai para o cliente (NEXT_PUBLIC); a privada é SEGREDO (só no servidor).
# Na Vercel: configure as três em Settings -> Environment Variables.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:voce@seudominio.com

# -----------------------------------------------------------------------------
# IA (Etapa 11) — garçom virtual, upsell, cadastro por foto, insights, tradução.
# Crie a chave em https://console.anthropic.com -> API Keys. É SEGREDO (só servidor).
# Sem esta chave o app funciona normalmente, apenas sem os recursos de IA.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Opcional: modelo. Padrão claude-haiku-4-5 (mais barato). Para mais qualidade
# na foto do cardápio: claude-sonnet-5 ou claude-opus-4-8
# AI_MODEL=claude-haiku-4-5
# Opcional: limite diário de chamadas de IA por loja (padrão 300)
# AI_DAILY_LIMIT=300

# -----------------------------------------------------------------------------
# Cobrança do plano Pro (Mercado Pago Assinaturas) — opcional.
# O dinheiro vai para a SUA conta Mercado Pago (você cobra os lojistas).
# 1) Crie uma aplicação em https://www.mercadopago.com.br/developers -> Suas integrações
# 2) Copie o Access Token (produção ou teste) para MP_ACCESS_TOKEN
# 3) Em Webhooks, cadastre a URL: https://seu-app.vercel.app/api/mp/webhook (tópico Assinaturas)
# 4) A SERVICE_ROLE_KEY (Supabase -> Project Settings -> API) é usada só pelo webhook
#    para trocar o plano da loja. É SEGREDO — nunca vai para o cliente.
# Sem estas variáveis, o app funciona e o plano Pro é ativado manualmente no painel da plataforma.
# -----------------------------------------------------------------------------
MP_ACCESS_TOKEN=
SUPABASE_SERVICE_ROLE_KEY=
# Opcional: preço mensal do Pro em reais (padrão 49.90)
# MP_PRO_PRICE=49.90
