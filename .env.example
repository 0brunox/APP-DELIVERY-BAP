# =============================================================================
# Variáveis de ambiente — Delivery Super App
#
# LOCAL:  copie este arquivo para .env.local e preencha com as chaves do seu
#         projeto Supabase (Project Settings -> API, no painel do Supabase).
# VERCEL: configure estas MESMAS variáveis em
#         Project -> Settings -> Environment Variables (Production + Preview).
#
# O arquivo .env.local é ignorado pelo git (não sobe para o repositório).
# =============================================================================

# URL do projeto Supabase (ex.: https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública do Supabase — aceita o formato novo "sb_publishable_..."
# ou a "anon public" key clássica (JWT). Pode ir para o cliente: é protegida por RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Web Push (Etapa 7D) — notificações de novo pedido / status.
# Gere o par de chaves uma vez com:  npx web-push generate-vapid-keys --json
# A pública vai para o cliente (NEXT_PUBLIC); a privada é SEGREDO (só no servidor).
# Na Vercel: configure as três em Settings -> Environment Variables.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:voce@seudominio.com
